];Q3.forEach(q=>{if(!Array.isArray(q.c))q.c=[q.c];});}
Q1.forEach(q=>{if(!Array.isArray(q.c))q.c=[q.c];});

const PARTS = {
  1:{
    label:'Parte 1',
    aulas:['1','2','3'],
    aulaLabels:{'1':'Aula 1 · Verdadeiro Desenvolvimento + Obstáculos','2':'Aula 2 · Entre Inconformismo e Reformismo','3':'Aula 3 · Fundamentos Lusitanos + Expansão Comercial'},
    getQ: ()=>Q1.filter(q=>['1','2','3'].includes(q.a)),
    chipClass:'chip-1', h1em:'em-1', scClass:'sc-1', bsClass:'bs-1', pfClass:'pf-1',
    tagColors:{'1':'background:var(--c1l);color:var(--c1);border-color:var(--c1m);',
               '2':'background:#e8f5e8;color:#2a7a2a;border-color:#90c890;',
               '3':'background:#fdf5dc;color:#7a5c00;border-color:#e8c96a;'},
    accentVar:'--c1', accentLt:'--c1l',
    gradBtn:'linear-gradient(135deg,#0d6e6e,#2a7a2a)',
    gradProg:'linear-gradient(90deg,#0d6e6e,#2a7a2a)',
    subtitle:'Aulas 1, 2 e 3 · Celso Furtado'
  },
  2:{
    label:'Parte 2',
    aulas:['4','5'],
    aulaLabels:{'4':'Aula 4 · Darcy Ribeiro — Os Brasileiros','5':'Aula 5 · Furtado — Formação Econômica do Brasil, Caps. I–VII'},
    getQ: ()=>{initQ2();return Q2.filter(q=>['4','5'].includes(q.a));},
    chipClass:'chip-2', h1em:'em-2', scClass:'sc-2', bsClass:'bs-2', pfClass:'pf-2',
    tagColors:{'4':'background:var(--c2l);color:var(--c2);border-color:var(--c2m);',
               '5':'background:#fff4e8;color:#6a3a00;border-color:#e8b07a;'},
    accentVar:'--c2', accentLt:'--c2l',
    gradBtn:'linear-gradient(135deg,#8b1a4a,#7a5c00)',
    gradProg:'linear-gradient(90deg,#8b1a4a,#7a5c00)',
    subtitle:'Aula 4 · Darcy Ribeiro  |  Aula 5 · Furtado, Formação Econômica'
  },
  3:{
    label:'Parte 3',
    aulas:['6','7'],
    aulaLabels:{'6':'Aula 6 · Furtado — Pequena Introdução + Criatividade e Dependência (Cap. II)','7':'Aula 7 · Furtado — Criatividade e Dependência (Cap. III) + Pequena Introdução'},
    getQ: ()=>{initQ3();return Q3;},
    chipClass:'chip-3', h1em:'em-3', scClass:'sc-3', bsClass:'bs-3', pfClass:'pf-3',
    tagColors:{'6':'background:var(--c3l);color:var(--c3);border-color:var(--c3m);',
               '7':'background:#f0e8f8;color:#5a1a6a;border-color:#c090d8;'},
    accentVar:'--c3', accentLt:'--c3l',
    gradBtn:'linear-gradient(135deg,#3a2a8a,#5a1a6a)',
    gradProg:'linear-gradient(90deg,#3a2a8a,#5a1a6a)',
    subtitle:'Aula 6 · Pequena Introdução + Criatividade e Dependência (Cap. II)  |  Aula 7 · Cap. III'
  }
};

let currentPart=1, filter='all', pool=[], current=0, score=0;
let selected=new Set(), confirmed=false;
let by={};

function goToPart(p){
  if(p===2)initQ2();else if(p===3)initQ3();
  currentPart=p;
  filter='all';
  showScreen('start-screen');
  renderPartUI();
}

function renderPartUI(){
  const pt=PARTS[currentPart];
  
  [1,2,3].forEach(p=>{
    const btn=document.getElementById('pnav-'+p);
    btn.className='pnav-btn'+(p===currentPart?' active-'+p:'');
  });
  
  document.getElementById('hdr').innerHTML=`
    <div class="header-chip ${pt.chipClass}">Prova I – FEB · ${pt.label}</div> <h1>Quiz <em class="${pt.h1em}">FEB</em><br>${pt.label}</h1> <p>${pt.subtitle}</p>`;
  
  const fb=document.getElementById('filter-bar');
  const total=pt.getQ().length;
  let html=`<button class="filter-btn fb-all" id="f-all" onclick="setFilter('all')">Todos (${total})</button>`;
  pt.aulas.forEach((a,i)=>{
    const cls=['fb-a1','fb-a2','fb-a3','fb-a4','fb-a5','fb-a6','fb-a7'][parseInt(a)-1];
    const n=pt.getQ().filter(q=>q.a===a).length;
    html+=`<button class="filter-btn" id="f-${a}" onclick="setFilter('${a}')">Aula ${a} (${n})</button>`;
  });
  fb.innerHTML=html;
  updateFilterButtons();
  
  document.getElementById('start-card').className=`start-card ${pt.scClass}`;
  
  const pills=document.getElementById('aula-pills');
  pills.innerHTML=pt.aulas.map((a,i)=>{
    const colors=['background:var(--c1l);color:var(--c1);border-color:var(--c1m)',
                  'background:#e8f5e8;color:#2a7a2a;border-color:#90c890',
                  'background:#fdf5dc;color:#7a5c00;border-color:#e8c96a',
                  'background:var(--c2l);color:var(--c2);border-color:var(--c2m)',
                  'background:#fff4e8;color:#6a3a00;border-color:#e8b07a',
                  'background:var(--c3l);color:var(--c3);border-color:var(--c3m)',
                  'background:#f0e8f8;color:#5a1a6a;border-color:#c090d8'][parseInt(a)-1];
    return `<span class="pill" style="${colors}">${pt.aulaLabels[a]}</span>`;
  }).join('');
  
  const bs=document.getElementById('btn-start');
  bs.className=`btn-start ${pt.bsClass}`;
  
  const grad=pt.gradBtn;
  ['btn-confirm','btn-next','btn-restart'].forEach(id=>{
    document.getElementById(id).style.background=grad;
  });
  
  document.getElementById('prog').className='progress-fill '+pt.pfClass;
  
  }

function setFilter(f){
  filter=f;
  updateFilterButtons();
}

function updateFilterButtons(){
  const pt=PARTS[currentPart];
  
  document.querySelectorAll('.filter-bar .filter-btn').forEach(b=>b.className='filter-btn');
  
  const activeId='f-'+(filter==='all'?'all':filter);
  const el=document.getElementById(activeId);
  if(el){
    if(filter==='all') el.classList.add('fb-all');
    else el.classList.add('fb-a'+filter);
  }
}

function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

function startQuiz(){
  const pt=PARTS[currentPart];
  const src=filter==='all'?pt.getQ():pt.getQ().filter(q=>q.a===filter);
  pool=shuffle([...src]);
  current=0;score=0;
  by={};
  pt.aulas.forEach(a=>by[a]={ok:0,tot:0});
  showScreen('quiz-screen');
  renderQ();
}

function renderQ(){
  selected=new Set();confirmed=false;
  const pt=PARTS[currentPart];
  const q=pool[current],total=pool.length;
  const pct=Math.round((current/total)*100);
  document.getElementById('q-num-top').textContent='Questão '+(current+1)+' de '+total;
  document.getElementById('score-top').textContent=score+' acerto'+(score!==1?'s':'');
  document.getElementById('prog').style.width=pct+'%';
  
  const tag=document.getElementById('author-tag');
  tag.textContent='Aula '+q.a;
  tag.style.cssText=pt.tagColors[q.a]||'';
  document.getElementById('q-num-side').textContent=(current+1)+'/'+total;
  document.getElementById('q-text').textContent=q.q;
  const n=q.c.length;
  document.getElementById('q-instr').textContent=
    n===0?'Atenção: pode não haver nenhuma alternativa correta.':
    n===1?'Selecione a alternativa correta e confirme.':
    'Selecione todas as alternativas corretas (pode haver mais de uma) e confirme.';
  
  const opts=document.getElementById('opts');
  opts.innerHTML='';
  const accentStyle=`border-color:var(${pt.accentVar});background:var(${pt.accentLt});`;
  q.opts.forEach((txt,i)=>{
    const btn=document.createElement('button');
    btn.className='opt';
    btn.innerHTML=`<span class="ol">${'ABCD'[i]}</span><span>${txt}</span>`;
    btn.dataset.idx=i;
    btn.onclick=()=>toggleOpt(btn,i,accentStyle);
    opts.appendChild(btn);
  });
  document.getElementById('feedback').className='feedback-box';
  document.getElementById('feedback').innerHTML='';
  document.getElementById('btn-confirm').className='btn-act show';
  document.getElementById('btn-next').className='btn-act';
  document.getElementById('btn-next').textContent=current<pool.length-1?'Próxima':'Ver resultado';
}

function toggleOpt(btn,idx,accentStyle){
  if(confirmed)return;
  if(selected.has(idx)){
    selected.delete(idx);
    btn.classList.remove('selected');
    btn.style.cssText='';
    btn.querySelector('.ol').style.cssText='';
  } else {
    selected.add(idx);
    btn.classList.add('selected');
  }
}

function confirmAnswer(){
  if(confirmed)return;
  confirmed=true;
  const pt=PARTS[currentPart];
  const q=pool[current];
  const correct=new Set(q.c);
  const isCorrect=setsEqual(selected,correct);
  if(by[q.a]) by[q.a].tot++;
  if(isCorrect){score++;if(by[q.a])by[q.a].ok++;}
  document.querySelectorAll('#opts .opt').forEach(b=>{
    const i=parseInt(b.dataset.idx);
    b.disabled=true;
    b.classList.remove('selected');
    b.style.cssText='';
    b.querySelector('.ol').style.cssText='';
    if(correct.has(i)&&selected.has(i)) b.classList.add('correct');
    else if(correct.has(i)&&!selected.has(i)) b.classList.add('reveal');
    else if(!correct.has(i)&&selected.has(i)) b.classList.add('wrong');
  });
  const fb=document.getElementById('feedback');
  fb.innerHTML=q.exp;
  fb.className='feedback-box '+(isCorrect?'fb-ok':'fb-bad')+' show';
  document.getElementById('score-top').textContent=score+' acerto'+(score!==1?'s':'');
  document.getElementById('btn-confirm').className='btn-act';
  document.getElementById('btn-next').className='btn-act show';
}

function setsEqual(a,b){if(a.size!==b.size)return false;for(let x of a)if(!b.has(x))return false;return true;}

function nextQ(){
  current++;
  if(current>=pool.length){showResult();return;}
  renderQ();
  window.scrollTo({top:0,behavior:'smooth'});
}

function showResult(){
  const pt=PARTS[currentPart];
  showScreen('result-screen');
  const total=pool.length,pct=Math.round((score/total)*100);
  document.getElementById('r-num').textContent=score;
  document.getElementById('r-den').textContent='de '+total;
  
  document.getElementById('result-card').style.setProperty('--grad',pt.gradBtn);
  document.querySelector('.result-card::before');
    document.getElementById('result-card').style.setProperty('border-top-color', 'transparent');
  
  const sc=document.getElementById('score-circle');
  if(pct>=80){sc.style.background='linear-gradient(135deg,#f0fdf4,#dcfce7)';sc.style.borderColor='#4ade80';document.getElementById('r-num').style.color='#059669';}
  else if(pct>=60){sc.style.background='linear-gradient(135deg,#fef9ee,#fef3c7)';sc.style.borderColor='#fbbf24';document.getElementById('r-num').style.color='#92400e';}
  else{sc.style.background='';sc.style.borderColor='#f4a07a';document.getElementById('r-num').style.color='var('+pt.accentVar+')';}
  const labels=[[90,'Excelente! Domínio sólido dos textos.'],[75,'Muito bom! Revise os pontos que erraste.'],[60,'Razoável. Vale reler as seções críticas.'],[0,'Precisas reler o material com mais atenção.']];
  const e=labels.find(([t])=>pct>=t);
  document.getElementById('r-title').textContent=e[1];
  document.getElementById('r-sub').textContent=pct+'% de aproveitamento';
  document.getElementById('r-ok').textContent=score;
  document.getElementById('r-err').textContent=total-score;
  document.getElementById('r-pct').textContent=pct+'%';
  
  const barColors=['#0d6e6e','#2a7a2a','#7a5c00','#8b1a4a','#6a3a00','#3a2a8a','#5a1a6a'];
  const brows=document.getElementById('brows');
  brows.innerHTML='';
  pt.aulas.forEach(a=>{
    const d=by[a];if(!d||!d.tot)return;
    const p=Math.round((d.ok/d.tot)*100);
    const color=barColors[parseInt(a)-1];
    const row=document.createElement('div');
    row.className='brow';
    row.innerHTML=`<span class="brow-label">Aula ${a}</span><div class="brow-track"><div class="brow-bar" id="bb-${a}" style="background:${color}"></div></div><span class="brow-pct">${p}%</span>`;
    brows.appendChild(row);
    setTimeout(()=>{document.getElementById('bb-'+a).style.width=p+'%';},100);
  });
  window.scrollTo({top:0,behavior:'smooth'});
}

function restart(){
  showScreen('start-screen');
  renderPartUI();
}

function showScreen(id){
  ['start-screen','quiz-screen','result-screen'].forEach(s=>{
    document.getElementById(s).style.display=s===id?'block':'none';
  });
}


// Pré-carregar Q2 e Q3 quando o browser estiver ocioso
if('requestIdleCallback' in window){
  requestIdleCallback(()=>{ initQ2(); requestIdleCallback(initQ3); });
} else {
  setTimeout(()=>{ initQ2(); setTimeout(initQ3, 200); }, 1000);
}

goToPart(1);
</script>
