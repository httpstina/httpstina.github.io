1.5px solid var(--border);background:var(--card);font-size:12px;font-weight:500;cursor:pointer;color:var(--muted);transition:all .18s;font-family:inherit}.filter-btn:hover{border-color:#aaa;color:var(--ink)}.fb-all{background:var(--ink)!important;border-color:var(--ink)!important;color:#fff!important}.fb-a1{background:var(--c1)!important;border-color:var(--c1)!important;color:#fff!important}.fb-a2{background:#2a7a2a!important;border-color:#2a7a2a!important;color:#fff!important}.fb-a3{background:#7a5c00!important;border-color:#7a5c00!important;color:#fff!important}.fb-a4{background:var(--c2)!important;border-color:var(--c2)!important;color:#fff!important}.fb-a5{background:#6a3a00!important;border-color:#6a3a00!important;color:#fff!important}.fb-a6{background:var(--c3)!important;border-color:var(--c3)!important;color:#fff!important}.fb-a7{background:#5a1a6a!important;border-color:#5a1a6a!important;color:#fff!important}#start-screen{text-align:center}.start-card{background:var(--card);border-radius:22px;padding:2rem 1.75rem;border:1.5px solid var(--border);max-width:520px;margin:0 auto 1.5rem;box-shadow:0 6px 30px rgba(0,0,0,.07);position:relative;overflow:hidden}.start-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}.sc-1::before{background:linear-gradient(90deg,var(--c1),#2a7a2a,#7a5c00)}.sc-2::before{background:linear-gradient(90deg,var(--c2),#6a3a00)}.sc-3::before{background:linear-gradient(90deg,var(--c3),#5a1a6a)}.start-card h2{font-family:Georgia,'Times New Roman',serif;font-size:1.2rem;font-weight:400;margin-bottom:.8rem}.start-card p{font-size:.88rem;color:var(--muted);line-height:1.65;margin-bottom:.5rem}.aula-pills{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-top:1.2rem}.pill{font-size:11px;font-weight:500;padding:4px 12px;border-radius:16px;border:1px solid}.btn-start{display:inline-block;margin-top:1.5rem;padding:12px 36px;color:#fff;border:none;border-radius:30px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:transform .15s,opacity .15s}.btn-start:hover{transform:translateY(-1px);opacity:.9}.bs-1{background:linear-gradient(135deg,var(--c1),#2a7a2a)}.bs-2{background:linear-gradient(135deg,var(--c2),#7a5c00)}.bs-3{background:linear-gradient(135deg,var(--c3),#5a1a6a)}#quiz-screen{display:none}.progress-wrap{margin-bottom:1.1rem}.progress-meta{display:flex;justify-content:space-between;margin-bottom:6px}.progress-meta span{font-size:12px;color:var(--muted)}.progress-bar{height:5px;background:#ddd;border-radius:3px}.progress-fill{height:5px;border-radius:3px;transition:width .5s cubic-bezier(.4,0,.2,1)}.pf-1{background:linear-gradient(90deg,var(--c1),#2a7a2a)}.pf-2{background:linear-gradient(90deg,var(--c2),#7a5c00)}.pf-3{background:linear-gradient(90deg,var(--c3),#5a1a6a)}.q-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:.9rem}.author-tag{font-size:11px;font-weight:700;padding:3px 12px;border-radius:16px;letter-spacing:.04em;text-transform:uppercase;border:1px solid}.q-num{font-size:12px;color:var(--muted)}.q-card{background:var(--card);border-radius:18px;padding:1.75rem;border:1.5px solid var(--border);margin-bottom:.9rem;box-shadow:0 3px 18px rgba(0,0,0,.06)}.q-text{font-size:.97rem;font-weight:500;line-height:1.65;margin-bottom:.7rem;color:var(--ink)}.q-instr{font-size:11.5px;color:var(--muted);font-style:italic;margin-bottom:.9rem}.options{display:flex;flex-direction:column;gap:9px}.opt{padding:12px 15px;border:1.5px solid #dde8e8;border-radius:11px;background:#f8fbfb;cursor:pointer;text-align:left;font-size:13.5px;line-height:1.5;color:var(--ink);transition:all .16s;display:flex;align-items:flex-start;gap:10px;font-family:inherit}.opt:hover:not(:disabled){border-color:#aaa;background:#f0f4f4}.opt.selected{border-color:var(--ca);background:var(--cal)}.opt.selected .ol{background:var(--ca);color:#fff}.opt.correct{background:#f0fdf4;border-color:#4ade80;color:#14532d}.opt.correct .ol{background:#4ade80;color:#14532d}.opt.wrong{background:#fff4f0;border-color:#f4a07a;color:#7c2d12}.opt.wrong .ol{background:#f4a07a;color:#fff}.opt.reveal{border-color:var(--ca);background:var(--cal)}.opt.reveal .ol{background:var(--ca);color:#fff}.opt:disabled{cursor:default}.ol{display:inline-flex;align-items:center;justify-content:center;width:23px;height:23px;min-width:23px;border-radius:50%;background:#dde8e8;font-size:10.5px;font-weight:700;color:var(--muted)}.feedback-box{border-radius:12px;padding:13px 16px;font-size:12.5px;line-height:1.65;margin-top:.9rem;display:none;border:1.5px solid}.feedback-box.show{display:block}.fb-ok{background:#f0fdf4;color:#14532d;border-color:#86efac}.fb-bad{background:#fff4f0;color:#7c2d12;border-color:#f4a07a}.q-footer{display:flex;justify-content:flex-end;gap:9px;margin-top:.9rem}.btn-act{padding:10px 26px;color:#fff;border:none;border-radius:28px;font-size:13.5px;font-weight:600;cursor:pointer;display:none;font-family:inherit;transition:transform .14s,opacity .14s}.btn-act:hover{transform:translateY(-1px);opacity:.9}.btn-act.show{display:block}#result-screen{display:none;text-align:center}.result-card{background:var(--card);border-radius:22px;padding:2.2rem 1.75rem;border:1.5px solid var(--border);max-width:520px;margin:0 auto;box-shadow:0 6px 30px rgba(0,0,0,.07);position:relative;overflow:hidden}.result-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}.score-circle{width:110px;height:110px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 1.3rem;border:2px solid}.score-num{font-family:Georgia,'Times New Roman',serif;font-size:2.2rem;line-height:1}.score-den{font-size:11px;color:var(--muted);margin-top:2px}.result-title{font-family:Georgia,'Times New Roman',serif;font-size:1.2rem;font-weight:400;margin-bottom:.35rem}.result-sub{font-size:.85rem;color:var(--muted);margin-bottom:1.6rem}.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:1.6rem}.stat-box{padding:12px;background:var(--surface);border-radius:12px;border:1px solid var(--border)}.stat-num{font-size:1.4rem;font-weight:600}.stat-lbl{font-size:11px;color:var(--muted);margin-top:2px}.breakdown{margin-bottom:1.6rem}.breakdown h3{font-size:10.5px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px}.brow{display:flex;align-items:center;gap:9px;margin-bottom:8px;font-size:12px}.brow-label{width:52px;text-align:right;color:var(--muted);flex-shrink:0;font-size:11px}.brow-track{flex:1;height:7px;background:#e8eee8;border-radius:4px;overflow:hidden}.brow-bar{height:7px;border-radius:4px;transition:width .8s cubic-bezier(.4,0,.2,1);width:0}.brow-pct{width:34px;text-align:left;color:var(--muted);flex-shrink:0;font-size:11px}.btn-restart{padding:11px 30px;color:#fff;border:none;border-radius:28px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:inherit;margin-top:.5rem}@media(max-width:480px){header h1{font-size:1.55rem}.shell{padding:1.25rem .9rem 3rem}.q-card{padding:1.2rem .9rem}}</style>
